{
  "$schema": "https://anthropic.com/claude-code/plugin.schema.json",
  "name": "mumo",
  "version": "0.3.0",
  "description": "Multi-model deliberation panel. Diverse AI voices + claim-level reactions on contested decisions.",
  "author": {
    "name": "mumo",
    "url": "https://mumo.chat"
  },
  "homepage": "https://mumo.chat/install/claude-code",
  "repository": "https://github.com/mumo-chat/mumo-claude.git",
  "license": "MIT",
  "keywords": [
    "mcp",
    "deliberation",
    "multi-model",
    "claude",
    "gpt",
    "gemini",
    "panel",
    "architecture",
    "design-review",
    "code-review"
  ],
  "mcpServers": {
    "mumo": {
      "type": "http",
      "url": "https://mumo.chat/api/mcp",
      "headers": {
        "Authorization": "Bearer ${user_config.api_key}"
      }
    }
  },
  "userConfig": {
    "api_key": {
      "type": "string",
      "title": "mumo API Key",
      "description": "Platform key from https://mumo.chat/settings/api-keys (starts with mmo_live_)",
      "sensitive": true,
      "required": true
    }
  }
}
